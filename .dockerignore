# Version control
.git
.gitignore

# Secrets and local environment (never bake into the image)
.env
.env.local
.env.*.local

# Local Python / uv (image runs `uv sync` during build)
.venv
.python-version

# Bytecode and test tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# Large or host-specific data (mount volumes at runtime instead)
data/raw/**
data/processed/**
logs/**

# IDE and editor
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# Docs and misc (not needed to run the API)
README.md
LICENSE
.env.example
Dockerfile
.dockerignore

# OS junk
.DS_Store
Thumbs.db
